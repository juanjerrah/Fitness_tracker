{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/domain/*": ["src/domain/*"],
      "@/data/*": ["src/data/*"],
      "@/infrastructure/*": ["src/infrastructure/*"],
      "@/ui/*": ["src/ui/*"],
      "@/stores/*": ["src/stores/*"],
      "@/shared/*": ["src/shared/*"],
      "@/i18n": ["src/i18n/index.ts"],
      "@/i18n/*": ["src/i18n/*"],
      "@/lib/*": ["src/lib/*"],
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["node_modules", "__tests__"]
}
